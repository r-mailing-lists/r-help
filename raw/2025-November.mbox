> data_long <- data.frame(
+       value = c(10, 12, 15, 8, 9, 11),
+       time = factor(rep(c("before", "after"), each = 3))
+     )
> groups <- with(data_long, split(value, time))
> t.test(groups$before, groups$after, paired=TRUE)


