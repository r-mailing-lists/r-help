cbind does work on differently shaped ts objects so:

  a <- matrix(1:12,nrow=6)
  b <- matrix(5:12,nrow=4)

  tmp <- cbind(ts(a), ts(b))
  array(tmp, dim(tmp))

giving

       [,1] [,2] [,3] [,4]
  [1,]    1    7    5    9
  [2,]    2    8    6   10
  [3,]    3    9    7   11
  [4,]    4   10    8   12
  [5,]    5   11   NA   NA

