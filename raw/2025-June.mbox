Here is a "brute strength and stupidity" approach that may help.
Note I renamed your data.table to DT for my own convenience.

##===========================================##
# Load packages ------------------------------------------------------------
suppressMessages(library(data.table))

# Load dada. --------------------------------------------------------------

DT <- fread("raw.data.csv"); DT


# Subset data and rbind into one new data.table. -------------------------
mynames <- c("date", "price1", "vol1", "price2","vol2", "id")

ABC <- DT[, c(1, 2:5)][, id := "ABC"] ; names(ABC) <-  mynames
DEF <- DT[, c(1, 6:9)][, id := "DEF"] ; names(DEF) <- mynames

DT1 <- rbind(ABC, DEF)

# Create new variable "price". --------------------------------------------

DT1[, price := fcase(vol1 < vol2, price2, default = price1)][]


# Summary statistic using "by". -------------------------------------------

DT1[, .(mysum = sum(price)), by = id]

##===========================================##


