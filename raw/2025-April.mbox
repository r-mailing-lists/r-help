Here is the code:

# add a source column
trade_df <- all_trade_final %>%
  mutate(source = "trade") %>%
  rename(value = time) 
close_df <- token_daily_close %>%
  mutate(source = "close") %>%
  rename(value = time)
# binds the two tibbles
time_all <- bind_rows(trade_df, close_df) %>%
  arrange(value)
# remove day column
time_all <- time_all %>%
  select(-day, -source)

