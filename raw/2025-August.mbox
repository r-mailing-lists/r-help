? ? xlim = c(-5, 5)
? ) +
? theme_linedraw() +
? coord_cartesian(clip = "off")? ?# <--- allow arrows outside

p

# Force evaluation so we can edit
grid.force()

# Add arrows to curve ends
grid.edit("GRID.polyline", grep=TRUE,
? ? ? ? ? arrow=arrow(ends="both", type="closed"))
